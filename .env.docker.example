# Copia este archivo como .env. Usa rutas visibles para Docker Desktop.
# Para carpetas de red es preferible una ruta UNC accesible por Docker
# en lugar de una unidad mapeada X:/ o Y:/.
IC_PROJECT_DIR=C:/ruta/MT5_Autotester_agent_IC/MT5_Autotester_agent
SMB_SERVER=192.168.1.152
SMB_USERNAME=usuario-del-pc-remoto
SMB_DOMAIN=nombre-del-pc-remoto
# Usa comillas simples si contiene $ u otros caracteres especiales de Compose.
SMB_PASSWORD='contraseña-smb'
